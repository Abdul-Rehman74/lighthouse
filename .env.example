# ─────────────────────────────────────────────────────────────
# Lighthouse Daycare — environment variables
# Copy to `.env.local` for local dev. On Vercel, add these under
# Project → Settings → Environment Variables (do NOT commit secrets).
# ─────────────────────────────────────────────────────────────

# --- Database (MongoDB Atlas) ---
# Create a free M0 cluster at https://www.mongodb.com/atlas, add a database
# user, allow network access (0.0.0.0/0 for Vercel), then copy the SRV URI.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="lighthouse"

# --- Admin auth ---
# Long random string used to sign the admin session cookie.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
# Initial admin password — only used to seed the very first login.
# After that, change it from the admin Settings page (stored hashed in the DB).
ADMIN_PASSWORD="lighthouse"

# --- Email (SMTP via Nodemailer) ---
# Booking notifications are emailed here. Leave blank to disable email
# (bookings are still saved to the database).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"          # "true" for port 465, "false" for 587/STARTTLS
SMTP_USER="you@gmail.com"
SMTP_PASS="your-app-password" # Gmail: create an App Password (not your login password)
MAIL_FROM="Lighthouse Daycare <you@gmail.com>"
# Default booking-notification recipient(s). Comma-separated for multiple.
# This is only a fallback — the admin Settings page lets you manage the
# recipient list (up to 5) without touching env vars.
MAIL_TO="bookings@lighthousedaycare.com"

# --- Cloudinary (testimonial video upload) ---
# Free account at https://cloudinary.com — values from the dashboard.
# Cloud name is public (used in the browser); API key/secret are server-only
# (used for signed uploads + deleting videos). Leave blank to disable upload
# (YouTube/Vimeo links still work without Cloudinary).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
